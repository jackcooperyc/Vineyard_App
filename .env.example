# Database (Neon for production — see README)
# DATABASE_URL = Neon pooled URL (host contains "-pooler")
# DIRECT_URL   = Neon direct URL (for prisma db push / migrations)
# Use sslmode=verify-full on Neon (not require) — see OVERSIGHT.md
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# Mapbox — required for live vineyard map (Sprint 5)
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Weather — server-side only (Sprint 8 Phase 2)
WEATHER_PROVIDER="open-meteo"
# OPENWEATHER_API_KEY=""  # optional; required only if WEATHER_PROVIDER=openweather
