// Cooper Estate Vineyard Management — Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BlockStatus {
  ACTIVE
  FALLOW
  REPLANTING
}

enum BlockType {
  VINEYARD
  INFRASTRUCTURE
}

enum GrowthStage {
  DORMANT
}

enum MapColorMode {
  STATUS
  VARIETAL
}

enum VarietyColor {
  RED
  WHITE
  ROSE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskGpsSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum EquipmentStatus {
  ACTIVE
  IN_MAINTENANCE
  RETIRED
}

enum IrrigationStatus {
  SCHEDULED
  APPLIED
  MISSED
  SKIPPED
}

enum UserRole {
  OWNER
  MANAGER
  FIELD_WORKER
  READ_ONLY
}

enum NotificationChannel {
  EMAIL
}

enum TaskNotificationEventType {
  ASSIGNED
  CREATED
  COMPLETED
  IN_PROGRESS
  CANCELLED
  PAUSED
  DUE_SOON
  OVERDUE
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ─── Vineyard core ───────────────────────────────────────────────────────────

model Vineyard {
  id                     String                  @id @default(cuid())
  name                   String
  location               String?
  mapColorMode           MapColorMode            @default(VARIETAL)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  blocks                 Block[]
  environmentalThreshold EnvironmentalThreshold?
}

model Block {
  id                  String               @id @default(cuid())
  vineyardId          String
  code                String
  name                String
  acreage             Float?
  status              BlockStatus          @default(ACTIVE)
  blockType           BlockType            @default(VINEYARD)
  infrastructureType  String?
  perimeterM          Float?
  areaSqm             Float?
  elevMin             Float?
  elevMed             Float?
  elevMax             Float?
  growthStage         GrowthStage?
  colorHex            String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vineyard            Vineyard             @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
  plantings           Planting[]
  tasks               Task[]
  irrigationSchedules IrrigationSchedule[]
  irrigationRecords   IrrigationRecord[]
  notes_records       Note[]
  mapFeature          MapFeature?
  viticultureMetrics  ViticultureMetrics?
  blockRows           BlockRow[]
  taskBlocks          TaskBlock[]
  gpsSessions         TaskGpsSession[]

  @@unique([vineyardId, code])
  @@index([vineyardId])
  @@index([status])
  @@index([blockType])
}

model Variety {
  id        String        @id @default(cuid())
  name      String        @unique
  color     VarietyColor?
  colorHex  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plantings Planting[]
}

model Planting {
  id          String   @id @default(cuid())
  blockId     String
  varietyId   String
  vineCount   Int?
  yearPlanted Int?
  rootstock   String?
  rowSpacing  Float?
  vineSpacing Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  variety     Variety  @relation(fields: [varietyId], references: [id])

  @@index([blockId])
  @@index([varietyId])
}

// ─── Operations ──────────────────────────────────────────────────────────────

model TaskTypeDefinition {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  label                String
  iconName             String   @default("ListTodo")
  colorHex             String?
  sortOrder            Int      @default(0)
  active               Boolean  @default(true)
  showInQuickLog       Boolean  @default(true)
  defaultTitleTemplate String?
  defaultDueDaysOffset Int?
  tracksGpsProgress    Boolean  @default(false)
  defaultSwathWidthM Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tasks                Task[]

  @@index([active])
  @@index([sortOrder])
}

model Task {
  id                    String                 @id @default(cuid())
  blockId               String
  taskTypeId            String
  status                TaskStatus             @default(PENDING)
  title                 String
  description           String?
  dueDate               DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  assignedToId          String?
  createdById           String?
  equipmentId           String?
  lastKnownLat          Float?
  lastKnownLng          Float?
  coveragePct           Float?
  rowsCompleted         Int?
  rowsTotal             Int?
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  block                 Block                  @relation(fields: [blockId], references: [id], onDelete: Cascade)
  taskType              TaskTypeDefinition     @relation(fields: [taskTypeId], references: [id])
  assignedTo            User?                  @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy             User?                  @relation("TaskCreator", fields: [createdById], references: [id])
  equipment             Equipment?             @relation(fields: [equipmentId], references: [id])
  notificationDeliveries NotificationDelivery[]
  gpsSessions           TaskGpsSession[]
  taskBlocks            TaskBlock[]

  @@index([blockId])
  @@index([taskTypeId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedToId])
  @@index([createdById])
  @@index([deletedAt])
}

model Equipment {
  id                 String              @id @default(cuid())
  name               String
  type               String
  status             EquipmentStatus     @default(ACTIVE)
  serialNumber       String?
  photoUrl           String?
  lastServicedAt     DateTime?
  nextServiceAt      DateTime?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tasks              Task[]
  maintenanceRecords MaintenanceRecord[]

  @@index([status])
  @@index([deletedAt])
}

model MaintenanceRecord {
  id           String    @id @default(cuid())
  equipmentId  String
  performedAt  DateTime
  description  String?
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([performedAt])
  @@index([deletedAt])
}

model IrrigationSchedule {
  id        String    @id @default(cuid())
  blockId   String
  frequency String
  startDate DateTime
  volume    Float?
  method    String?
  active    Boolean   @default(true)
  notes     String?
  alertDismissedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  block     Block     @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@index([active])
  @@index([deletedAt])
}

model IrrigationRecord {
  id          String           @id @default(cuid())
  blockId     String
  scheduledAt DateTime?
  appliedAt   DateTime
  volume      Float?
  duration    Int?
  method      String?
  status      IrrigationStatus @default(APPLIED)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  block       Block            @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@index([appliedAt])
  @@index([status])
  @@index([deletedAt])
}

// ─── Shared ──────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  blockId   String?
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  block     Block?   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([blockId])
  @@index([authorId])
}

model MapFeature {
  id        String   @id @default(cuid())
  blockId   String   @unique
  geometry  Json
  centerLat Float
  centerLng Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model BlockRow {
  id        String   @id @default(cuid())
  blockId   String
  rowIndex  Int
  geometry  Json
  lengthM   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, rowIndex])
  @@index([blockId])
}

model TaskBlock {
  id            String   @id @default(cuid())
  taskId        String
  blockId       String
  sortOrder     Int      @default(0)
  isPrimary     Boolean  @default(false)
  coveragePct   Float?
  rowsCompleted Int?
  rowsTotal     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  block         Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockId])
  @@index([taskId])
  @@index([blockId])
}

model TaskGpsSession {
  id          String               @id @default(cuid())
  taskId      String
  blockId     String?
  userId      String
  startedAt   DateTime             @default(now())
  endedAt     DateTime?
  swathWidthM Float?
  status      TaskGpsSessionStatus @default(ACTIVE)
  coveragePct Float?
  rowsVisited Int?
  pointCount  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  task        Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  block       Block?               @relation(fields: [blockId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id])
  points      TaskGpsPoint[]

  @@index([taskId])
  @@index([blockId])
  @@index([userId])
  @@index([status])
}

model TaskGpsPoint {
  id         String         @id @default(cuid())
  sessionId  String
  lat        Float
  lng        Float
  accuracyM  Float?
  speedMps   Float?
  heading    Float?
  recordedAt DateTime
  session    TaskGpsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, recordedAt])
}

model IrrigationPump {
  id               String   @id @default(cuid())
  name             String?
  gpsPoint         Json
  flowCapacity     Float?
  servicedBlockIds String[]
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum TourPOICategory {
  MILESTONE
  FAMILY
  VARIETAL
  TERROIR
  CLUB_STORY
  HYPE_FUTURE_EXPERIENCE
  PHOTO_OPPORTUNITY
  TASTING_BAR
  BATHROOM_ACCESS
}

model TourPOI {
  id          String          @id @default(cuid())
  title       String
  description String?
  category    TourPOICategory
  gpsPoint    Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EnvironmentalThreshold {
  id                String   @id @default(cuid())
  vineyardId        String   @unique
  frostWarningTempF Float
  heatStressTempF   Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  vineyard          Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
}

model ViticultureMetrics {
  id                String    @id @default(cuid())
  blockId           String    @unique
  currentNdviScore  Float?
  cumulativeGdd     Float?
  lastSatellitePass DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  block             Block     @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
}

// ─── Auth (Auth.js) ──────────────────────────────────────────────────────────

model User {
  id                       String                      @id @default(cuid())
  name                     String?
  email                    String                      @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  role                     UserRole                    @default(MANAGER)
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  tasks                    Task[]                      @relation("TaskAssignee")
  createdTasks             Task[]                      @relation("TaskCreator")
  notes                    Note[]
  notificationPreference   UserNotificationPreference?
  notificationDeliveries   NotificationDelivery[]
  taskGpsSessions          TaskGpsSession[]
}

model UserNotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailAssigned   Boolean  @default(true)
  emailCreated    Boolean  @default(false)
  emailCompleted  Boolean  @default(true)
  emailInProgress Boolean  @default(true)
  emailCancelled  Boolean  @default(true)
  emailPaused     Boolean  @default(true)
  emailDueSoon    Boolean  @default(true)
  emailOverdue    Boolean  @default(true)
  dueSoonHours    Int      @default(24)
  quietHoursStart Int?
  quietHoursEnd   Int?
  timezone        String   @default("America/Los_Angeles")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationDelivery {
  id              String                     @id @default(cuid())
  taskId          String?
  eventType       TaskNotificationEventType
  channel         NotificationChannel        @default(EMAIL)
  recipientUserId String
  status          NotificationDeliveryStatus @default(PENDING)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  task            Task?                      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  recipientUser   User                       @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([recipientUserId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([taskId, eventType, recipientUserId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
